class Student:
    def __init__(self, marks):
        self.__marks = None
        self.set_marks(marks)

    def get_marks(self):
        return self.__marks

    def set_marks(self, marks):
        if 0 <= marks <= 100:
            self.__marks = marks
        else:
            raise ValueError("Marks must be between 0 and 100")

s = Student(85)
print(s.get_marks())  # 85
